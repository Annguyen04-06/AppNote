rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User collection
    match /users/{userId} {
      // Anyone can read their own user document
      allow read: if request.auth.uid == userId;
      // Admin can read all user documents
      allow read: if isAdmin(request.auth.uid);
      
      // Only on initial registration or admin
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin(request.auth.uid);
      allow delete: if isAdmin(request.auth.uid);
    }

    // Activity logs collection
    match /activity_logs/{document=**} {
      // Anyone authenticated can write their own activity logs
      allow create: if request.auth != null;
      // Users can only read their own logs, admin can read all
      allow read: if request.auth.uid == resource.data.userId || isAdmin(request.auth.uid);
      // Admin can delete logs
      allow delete: if isAdmin(request.auth.uid);
    }

    // Helper function to check if user is admin
    function isAdmin(uid) {
      return uid != null && 
             get(/databases/$(database)/documents/users/$(uid)).data.role == 'admin';
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
